    "vis-network": "^9.1.9"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
