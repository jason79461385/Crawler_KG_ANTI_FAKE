# ============================================================
# Scam Intel Console - 環境變數範本
# 全部都是「可選」的 — 沒設定的會 graceful fallback
# 複製為 .env 後按需填寫
# ============================================================

# ---------- Neo4j(知識圖譜持久化)----------
# 若有跑 `npm run db:up`,直接用以下預設值即可
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=password123
NEO4J_DATABASE=neo4j
# 多久前的節點視為過期,會被增量 sync 清掉(預設 7 天)
NEO4J_STALE_HOURS=168
# 連線 timeout,避免本機沒 Neo4j 時第一次 /api/graph 卡住
NEO4J_CONNECT_TIMEOUT_MS=2000

# ---------- LLM(OpenAI 相容 chat/completions)----------
# 設定後 /api/analyze 與 /api/chat 會走真實 LLM
# 支援 Ollama / vLLM / OpenAI / 自架 gateway
# 也支援 URL 內嵌 basic auth: https://user:pass@host/v1
# WORKER_API_URL=https://your-llm.example.com/v1
# WORKER_MODEL_NAME=qwen3.5:9b
# WORKER_API_KEY=sk-xxx

# ---------- Embedding(OpenAI 相容 embeddings)----------
# 設定後評分公式會加上 cosine similarity 那層(權重 ×42)
# EMBEDDING_API_URL=https://your-emb.example.com/v1
# EMBEDDING_MODEL_NAME=multilingual-e5-large
# EMBEDDING_API_KEY=sk-xxx

# ---------- 威脅情資(/api/verify-site 強化)----------
# Google Safe Browsing v4(免費 10K queries/day)
# GOOGLE_SAFE_BROWSING_KEY=AIzaSy...
# PhishTank(需申請 API key)
# PHISHTANK_FEED_URL=https://data.phishtank.com/data/<key>/online-valid.json
# OpenPhish(預設值即可,免註冊)
# OPENPHISH_FEED_URL=https://openphish.com/feed.txt
# 威脅情資 feed 多久重抓一次(小時)
PHISH_REFRESH_HOURS=12
